rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 3. Primitive Definition
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Validation Blueprints
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'referralCode', 'clicks', 'conversions', 'rewards', 'createdAt'])
        && data.keys().size() == 7
        && data.uid is string && data.uid.size() <= 128
        && data.email is string && data.email.size() <= 256
        && data.referralCode is string && data.referralCode.size() == 6
        && data.clicks is number
        && data.conversions is number
        && data.rewards is number
        && data.createdAt is string; // ISO format
    }

    // Users collection
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && request.query.limit <= 1;
      
      allow create: if isOwner(userId) && isVerified()
        && isValidUser(incoming())
        && incoming().uid == userId
        && incoming().clicks == 0
        && incoming().conversions == 0
        && incoming().rewards == 0;
        
      allow update: if (isValidUser(incoming()) && (
        isOwner(userId) ||
        // Action: Track Click (can be public/visitor)
        (incoming().diff(existing()).affectedKeys().hasOnly(['clicks']) 
         && incoming().clicks == existing().clicks + 1) ||
        // Action: Reward Conversion
        (isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['conversions', 'rewards']) 
         && incoming().conversions == existing().conversions + 1
         && incoming().rewards == (existing().rewards + 5.0)
         && existsAfter(/databases/$(database)/documents/referrals/$(userId + "_" + request.auth.uid)))
      ));
    }

    // Referrals collection
    match /referrals/{referralId} {
      allow read: if isSignedIn() && (existing().referrerUid == request.auth.uid || existing().referredUid == request.auth.uid);
      allow create: if isVerified() 
        && incoming().referredUid == request.auth.uid
        && incoming().timestamp == request.time;
    }

    // Clicks collection
    match /clicks/{clickId} {
      allow create: if true; // Public can log a click
      allow read: if isSignedIn() && existing().referrerUid == request.auth.uid;
    }
    
    // Connection test doc
    match /test/connection {
      allow get: if true;
    }
  }
}
