rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Users collection
    match /users/{userId} {
      // Allow signed-in users to read their own profile, and allow public search by referral code
      allow get: if isSignedIn(); 
      allow list: if true; // Public needs to find referrers by code
      
      allow create: if isOwner(userId);
      
      allow update: if isOwner(userId)
        || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['clicks']));
    }

    // Referrals collection
    match /referrals/{referralId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
    }

    // Clicks collection
    match /clicks/{clickId} {
      allow create: if true; // Visitors can log clicks
      allow read: if isSignedIn();
    }

    // Test connection doc
    match /test/connection {
      allow get: if true;
    }
  }
}
